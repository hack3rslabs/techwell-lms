  id                  String            @id @default(cuid())
  employerId          String?
  isOffCampus         Boolean           @default(false)
  eligibilityCriteria Json?
  title               String
  description         String?
  skills              String[]          @default([])
  jobRole             String?
  salary              String?
  openings            Int?
  hiringMode          HiringMode        @default(CAMPUS)
  status              CampusDriveStatus @default(REQUESTED)
  targetYear          String? // Graduation year e.g. "2024"
  departments         String[]          @default([])
  location            String?
  scheduledDate       DateTime?
  completedDate       DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  assessmentLink String?
  workflowStages Json? // To track custom pipeline stages

  // Dynamic Job Mela Builder Configs
  participatingCompanies Json? // List of companies with name, logo, roles, etc.
  customFormFields       Json? // Array of field configurations for the lead gen form
  brandingAssets         Json? // Custom banner, primary color, logos, etc.
  hostType               String? @default("TECHWELL")
  hostName               String?
  hostLogo               String?
  linkedCourseId         String?

  employer   User?                  @relation("EmployerCampusDrives", fields: [employerId], references: [id])
  institutes CampusDriveInstitute[]
  students   CampusDriveStudent[]
}

model CampusDriveInstitute {
  id          String   @id @default(cuid())
  driveId     String
  instituteId String
  status      String   @default("INVITED") // INVITED, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drive     CampusDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  institute Institute   @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@unique([driveId, instituteId])
}

model CampusDriveStudent {
  id      String @id @default(cuid())
  driveId String
  userId  String

  targetEmployerId String? // Added for Multi-Company Job Melas
  targetRole       String? // Added for Multi-Company Job Melas

  status         String   @default("ELIGIBLE") // ELIGIBLE, INVITED, REGISTERED, ASSESSMENT, SHORTLISTED, GD, TECH_INTERVIEW, HR_INTERVIEW, SELECTED, OFFERED, JOINED, REJECTED, WITHDRAWN
  resumeUrl      String?
  offerLetterUrl String?
  ctc            String?
  atsScore       Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  drive CampusDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BulkUploadLog {
  id           String   @id @default(cuid())
  instituteId  String
  uploadedBy   String
  filename     String
  totalRecords Int
  successCount Int
  failedCount  Int
  errors       Json?
  createdAt    DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [uploadedBy], references: [id])
}

model ConsultancyCoordination {
  id              String   @id @default(cuid())
  employerId      String
  instituteId     String
  techwellAdminId String
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  revenue         Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employer      User      @relation("EmployerCoordination", fields: [employerId], references: [id])
  institute     Institute @relation(fields: [instituteId], references: [id])
  techwellAdmin User      @relation("AdminCoordination", fields: [techwellAdminId], references: [id])
}

model Customer {
  id               String    @id @default(cuid())
  customerNo       String?   @unique
  email            String?   @unique
  phone            String?   @unique
  name             String
  globalLeadScore  Float     @default(0)
  lifetimeValue    Float     @default(0)
  lastContactedAt  DateTime?
  primarySource    String?
  aiSummary        String?
  aiNextBestAction String?
  aiPriority       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  users              User[]
  leads              Lead[]
  candidateProfiles  CandidateProfile[]
  pipelines          PipelineDeal[]
  callLogs           CallLog[]
  proposals          Proposal[]
  invoices           Invoice[]
  consultingProjects ConsultingProject[]
  tags               String[]            @default([])
  customFields       Json?
  assignedToId       String?
  assignee           User?               @relation("AssignedCustomers", fields: [assignedToId], references: [id])
  followUpTasks      FollowUpTask[]
  communicationLogs  CommunicationLog[]
  agreements         ClientAgreement[]
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  vertical  String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stages    PipelineStage[]
  deals     PipelineDeal[]
}

model PipelineStage {
  id         String         @id @default(cuid())
  pipelineId String
  name       String
  orderIndex Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      PipelineDeal[]
}

model PipelineDeal {
  id                String        @id @default(cuid())
  customerId        String
  pipelineId        String
  stageId           String
  title             String
  value             Float         @default(0)
  probability       Int           @default(0)
  status            String        @default("OPEN") // OPEN, WON, LOST
  assignedTo        String?
  expectedCloseDate DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pipeline          Pipeline      @relation(fields: [pipelineId], references: [id])
  stage             PipelineStage @relation(fields: [stageId], references: [id])
}

model CallLog {
  id           String   @id @default(cuid())
  customerId   String
  agentId      String?
  duration     Int      @default(0) // seconds
  direction    String   @default("OUTBOUND") // INBOUND, OUTBOUND
  status       String   @default("COMPLETED")
  recordingUrl String?
  aiSummary    String?
  notes        String?
  timestamp    DateTime @default(now())
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Proposal {
  id         String    @id @default(cuid())
  customerId String
  title      String
  fileUrl    String?
  status     String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  value      Float     @default(0)
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String    @id @default(cuid())
  customerId String
  invoiceNum String    @unique
  amount     Float
  status     String    @default("UNPAID") // UNPAID, PAID, CANCELLED
  dueDate    DateTime?
  fileUrl    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model FollowUpTask {
  id          String    @id @default(cuid())
  leadId      String?
  customerId  String?
  title       String
  description String?
  dueDate     DateTime
  status      String    @default("PENDING")
  assignedTo  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CommunicationLog {
  id         String    @id @default(cuid())
  leadId     String?
  customerId String?
  type       String
  direction  String
  status     String
  content    String?
  metadata   Json?
  timestamp  DateTime  @default(now())
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model AgreementTemplate {
  id         String            @id @default(cuid())
  vertical   String
  title      String
  content    String // HTML or rich text template
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  agreements ClientAgreement[]
}

model LegalClause {
  id        String   @id @default(cuid())
  title     String
  category  String // NDA, SLA, REFUND, IP, etc.
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientAgreement {
  id              String    @id @default(cuid())
  agreementNum    String    @unique
  customerId      String
  templateId      String?
  vertical        String
  title           String
  status          String    @default("DRAFT") // DRAFT, SENT, SIGNED, ACTIVE, EXPIRED, RENEWED, CANCELLED
  content         String // The full rich text content
  totalValue      Float     @default(0)
  taxPercentage   Float     @default(0)
  taxAmount       Float     @default(0)
  grandTotal      Float     @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  pdfUrl          String?
  clientSignature String? // Base64 or URL
  clientSignedAt  DateTime?
  clientPhotoUrl  String? // Base64 or URL for live photo
  clientPhotoAt   DateTime?
  clientIp        String?
  adminSignature  String?
  adminSignedAt   DateTime?
  adminId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template          AgreementTemplate?   @relation(fields: [templateId], references: [id])
  milestones        AgreementMilestone[]
  versions          AgreementVersion[]
  consultingProject ConsultingProject?
}

model AgreementMilestone {
  id          String    @id @default(cuid())
  agreementId String
  title       String
  description String?
  amount      Float
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING, COMPLETED, INVOICED, PAID
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agreement ClientAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
}

model AgreementVersion {
  id          String   @id @default(cuid())
  agreementId String
  versionNum  Int
  content     String
  changes     String?
  createdAt   DateTime @default(now())

  agreement ClientAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
}

model SeoMetadata {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String?
  description String?
  keywords    String?
  canonical   String?
  ogImage     String?
  noIndex     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RedirectRule {
  id          String   @id @default(cuid())
  source      String   @unique
  destination String
  permanent   Boolean  @default(true) // 301 if true, 302 if false
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoAnalytics {
  id        String   @id @default(cuid())
  path      String
  type      String // e.g., "404", "SLOW_LOAD"
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model SuccessStory {
  id        String   @id @default(cuid())
  imagePath String
  url       String?
  altText   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminDocument {
  id          String   @id @default(cuid())
  name        String
  description String?
  filePath    String
  fileSize    Int      @default(0)
  category    String   @default("GENERAL")
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterCampaign {
  id          String    @id @default(uuid())
  subject     String
  htmlContent String    @db.Text
  status      String    @default("DRAFT") // DRAFT, PUBLISHED, SENT
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ConsultingType {
  BUSINESS
  IT
  SOFTWARE
  WEB
  CYBER_SECURITY
  OTHER
}

enum ConsultingStatus {
  ONBOARDING
  PLANNING
  EXECUTION
  REVIEW
  DELIVERY
  ON_HOLD
  CANCELLED
}

model ConsultingProject {
  id          String           @id @default(cuid())
  title       String
  description String?          @db.Text
  type        ConsultingType
  status      ConsultingStatus @default(ONBOARDING)
  clientId    String?
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?         @default(0)
  agreementId String?          @unique
  assigneeId  String?
  webUrl      String?
  commitment  String?          @db.Text
  notes       String?          @db.Text
  contacts    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  milestones ConsultingMilestone[]
  resources  ConsultingResource[]
  client     Customer?             @relation(fields: [clientId], references: [id])
  agreement  ClientAgreement?      @relation(fields: [agreementId], references: [id])
  assignee   User?                 @relation(fields: [assigneeId], references: [id])
}

model ConsultingMilestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project ConsultingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ConsultingResource {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  role           String
  hoursAllocated Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project ConsultingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// FRANCHISE MANAGEMENT MODELS
// -----------------------------------------------------------------------------

model Franchise {
  id                   String   @id @default(cuid())
  name                 String
  franchiseType        String   @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  contactPerson        String
  email                String   @unique
  phone                String
  address              String?
  state                String?
  district             String?
  mandal               String?
  city                 String?
  pincode              String?
  nearbyLeadsRadius    Int      @default(10) // km radius
  exclusiveTerritory   Boolean  @default(false)
  geoLocation          String?
  googleMapsUrl        String?
  googleBusinessUrl    String?
  website              String?
  socialMedia          Json?
  logoUrl              String?
  branchCode           String?  @unique
  businessHours        Json?
  gallery              String[] @default([])
  status               String   @default("PENDING") // PENDING, ACTIVE, SUSPENDED, EXPIRED
  adminRemarks         String?
  approvedById         String?
  royaltyPercentage    Float    @default(30.0) // 30% goes to Techwell
  commissionPercentage Float    @default(0.0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users                User[]
  courses              Course[]
  certificates         Certificate[]
  leads                Lead[]
  verifications        FranchiseVerification[]
  subscriptions        FranchiseSubscription[]
  revenues             FranchiseRevenue[]
  agreements           FranchiseAgreement[]
  payments             Payment[]
  ledgers              FranchiseLedger[]
  resources            FranchiseResource[]
  certificateTemplates CertificateTemplate[]

  approvedBy User? @relation("FranchiseApprover", fields: [approvedById], references: [id])
}

model FranchiseVerification {
  id                  String    @id @default(cuid())
  franchiseId         String    @unique
  panNumber           String?
  panUrl              String?
  gstNumber           String?
  gstUrl              String?
  msmeNumber          String?
  msmeUrl             String?
  firmRegistrationUrl String?
  tradeLicenseUrl     String?
  aadhaarNumber       String?
  aadhaarUrl          String?
  addressProofUrl     String?
  bankDetails         Json?
  cancelledChequeUrl  String?
  digitalSignatureUrl String?
  otherDocuments      Json?
  status              String    @default("PENDING") // PENDING, APPROVED, REJECTED
  remarks             String?
  verifiedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model FranchiseSubscription {
  id                  String    @id @default(cuid())
  franchiseId         String
  planName            String
  registrationFee     Float     @default(0)
  franchiseFee        Float     @default(0)
  renewalFee          Float     @default(0)
  securityDeposit     Float     @default(0)
  totalAmount         Float     @default(0)
  status              String    @default("PENDING") // PENDING, PAID, CANCELLED, EXPIRED
  paymentId           String?
  startDate           DateTime?
  endDate             DateTime?
  renewalReminderSent Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model FranchiseRevenue {
  id              String    @id @default(cuid())
  franchiseId     String
  transactionType String // STUDENT_FEE, ROYALTY, COMMISSION
  amount          Float     @default(0)
  franchiseShare  Float     @default(0)
  techwellShare   Float     @default(0)
  status          String    @default("PENDING") // PENDING, SETTLED
  studentId       String?
  enrollmentId    String?
  settlementDate  DateTime?
  referenceId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model FranchiseAgreement {
  id                  String    @id @default(cuid())
  franchiseId         String
  version             String    @default("1.0")
  content             String    @db.Text
  digitalSignatureUrl String?
  termsAccepted       Boolean   @default(false)
  acceptedAt          DateTime?
  ipAddress           String?
  status              String    @default("ACTIVE") // ACTIVE, EXPIRED, RENEWED
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model FranchiseLedger {
  id              String   @id @default(cuid())
  franchiseId     String
  transactionType String // CREDIT (Techwell owes Franchise), DEBIT (Franchise owes Techwell), SETTLEMENT (Payment made)
  amount          Float
  balanceAfter    Float
  description     String?
  referenceId     String? // e.g., Enrollment ID or Payment ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model FranchiseResource {
  id           String   @id @default(cuid())
  franchiseId  String? // If null, it's global for all franchises
  title        String
  description  String?
  fileUrl      String
  resourceType String // BROCHURE, BANNER, SYLLABUS, VIDEO
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  franchise Franchise? @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
}

model Assessment {
  id            String               @id @default(cuid())
  title         String
  description   String?
  type          String               @default("MCQ") // MCQ, CODING, MIXED
  duration      Int                  @default(60) // in minutes
  passingScore  Int                  @default(50)
  employerId    String
  courseId      String?
  isPublished   Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  employer      User                 @relation(fields: [employerId], references: [id])
  course        Course?              @relation(fields: [courseId], references: [id])
  questions     AssessmentQuestion[]
  attempts      AssessmentAttempt[]
}

model AssessmentQuestion {
  id           String     @id @default(cuid())
  assessmentId String
  text         String
  type         String     @default("MCQ") // MCQ, CODING
  options      Json?      // e.g. ["A", "B", "C", "D"]
  correctAnswer String?
  marks        Int        @default(1)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentAttempt {
  id           String     @id @default(cuid())
  assessmentId String
  userId       String
  score        Float      @default(0)
  status       String     @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED
  responses    Json?      // Map of questionId -> user response
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  proctorLogs  Json?      // Array of tab switches, warnings

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, userId])
}

// Gamification Models
model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  iconUrl     String?     // URL or lucide icon name
  xpRequired  Int         @default(0)
  createdAt   DateTime    @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
