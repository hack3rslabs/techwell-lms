# Environment variables - NEVER commit these
.env
.env.local
.env.*.local

# Dependencies - auto-installed, don't commit
node_modules/
/.pnp
.pnp.js

# Testing
/coverage

# Production builds - generated, don't commit
/build
/dist
.next/
out/

# Misc
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE settings
.idea/
.vscode/
*.swp
*.swo
*~

# WhatsApp session - LARGE FILES, never commit
.wwebjs_auth/
.wwebjs_cache/
backend/.wwebjs_auth/
backend/.wwebjs_cache/

# Upload temp files
uploads/temp/*
backend/uploads/temp/*

# Recovery/debug files
.lost_found_blobs/
replace_emails.js

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
