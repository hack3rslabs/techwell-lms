model StaffGoal {
  id            String   @id @default(cuid())
  userId        String
  goalType      String // REVENUE, ENROLLMENTS, CALLS
  targetValue   Float
  achievedValue Float    @default(0)
  month         Int
  year          Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, goalType, month, year])
}

model FollowUpTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String // WHATSAPP, EMAIL, SCRIPT
  category  String // Initial Contact, Follow-up, Discount Offer, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffAttendance {
  id           String    @id @default(cuid())
  userId       String
  date         DateTime  @db.Date
  checkInTime  DateTime
  checkOutTime DateTime?
  totalHours   Float?
  status       String    @default("PRESENT") // PRESENT, ABSENT, LEAVE
  location     String?
  ipAddress    String?
  photoUrl     String? // Initial check-in photo
  sessions     Json? // Array of break sessions [{checkIn: Time, checkOut: Time}]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// --- INTERNSHIP MANAGEMENT MODULE ---

model InternshipProgram {
  id              String                 @id @default(cuid())
  title           String
  department      String
  description     String
  durationMonths  Int                    @default(6)
  skillsRequired  String[]
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  enrollments     InternshipEnrollment[]
}

model InternshipEnrollment {
  id              String               @id @default(cuid())
  userId          String
  programId       String
  mentorId        String?
  status          String               @default("PENDING") // PENDING, ACTIVE, COMPLETED, DROPPED
  startDate       DateTime?
  endDate         DateTime?
  offerConverted  Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user            User                 @relation("InternUser", fields: [userId], references: [id])
  mentor          User?                @relation("InternMentor", fields: [mentorId], references: [id])
  program         InternshipProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  dailyLogs       InternshipLog[]
  tasks           InternshipTask[]
  evaluation      InternshipEvaluation?
}

model InternshipLog {
  id              String               @id @default(cuid())
  enrollmentId    String
  date            DateTime             @default(now())
  hoursLogged     Float
  tasksCompleted  String
  blockers        String?
  mentorFeedback  String?
  status          String               @default("SUBMITTED") // SUBMITTED, REVIEWED
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  enrollment      InternshipEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model InternshipTask {
  id              String               @id @default(cuid())
  enrollmentId    String
  title           String
  description     String?
  dueDate         DateTime?
  status          String               @default("ASSIGNED") // ASSIGNED, IN_PROGRESS, COMPLETED
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  enrollment      InternshipEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model InternshipEvaluation {
  id              String               @id @default(cuid())
  enrollmentId    String               @unique
  performanceScore Float               @default(0)
  mentorComments  String
  offerRecommended Boolean             @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  enrollment      InternshipEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// --- HR & PAYROLL MODULE ---

model StaffPayroll {
  id              String   @id @default(cuid())
  userId          String
  month           Int
  year            Int
  baseSalary      Float
  totalHours      Float    @default(0)
  bonus           Float    @default(0)
  deductions      Float    @default(0)
  netAmount       Float
  status          String   @default("PENDING") // PENDING, PAID
  paymentDate     DateTime?
  paymentMethod   String?
  transactionRef  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

// ─── MARKETING CRM MODELS ───────────────────────────────────────────────

model LandingPage {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  htmlContent  String?  @db.Text
  customCss    String?  @db.Text
  customJs     String?  @db.Text
  headerCode   String?  @db.Text
  content      Json?
  status       String   @default("DRAFT")
  seoTitle     String?
  seoDesc      String?
  ogImage      String?
  pagePassword String?
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LeadGenForm {
  id             String   @id @default(cuid())
  title          String
  fields         Json
  submitMessage  String?
  redirectUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MarketingCampaign {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("EMAIL") // EMAIL, SMS, WHATSAPP, ADS
  status      String   @default("DRAFT") // ACTIVE, COMPLETED, DRAFT
  budget      Float?
  roiScore    Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdBanner {
  id           String    @id @default(cuid())
  title        String
  businessName String?
  contactInfo  String?
  imageUrl     String
  targetUrl    String?
  position     String    @default("RIGHT_1") // LEFT_1, LEFT_2, RIGHT_1, RIGHT_2, TOP_BANNER
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  durationDays Int?      // 7, 15, 30
  isPermanent  Boolean   @default(false)
  autoRenewal  Boolean   @default(false)
  expiresAt    DateTime?
  views        Int       @default(0)
  clicks       Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ReferralReward {
  id              String   @id @default(cuid())
  referrerId      String
  referredId      String
  amount          Float
  status          String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  type            String   @default("COMMISSION") // COMMISSION, DISCOUNT
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  referrer        User     @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        User     @relation("ReferredRewards", fields: [referredId], references: [id], onDelete: Cascade)
}
