generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                    @id @default(cuid())
  email                       String                    @unique
  password                    String
  name                        String
  role                        Role                      @default(STUDENT)
  avatar                      String?
  phone                       String?
  isActive                    Boolean                   @default(true)
  emailVerified               Boolean                   @default(false)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  permissions                 Json?
  plan                        Plan                      @default(FREE)
  hasResumeAccess             Boolean                   @default(false)
  hasAiInterviewAccess        Boolean                   @default(false)
  location                    String?
  instituteId                 String?
  systemRoleId                String?
  college                     String?
  dob                         DateTime?
  qualification               String?
  leadLastSeenAt              DateTime?
  trustedDevices              Json?                     @default("[]")
  twoFactorEnabled            Boolean                   @default(false)
  twoFactorSecret             String?
  twoFactorTempSecret         String?
  deleteRequestDate           DateTime?
  deleteRequested             Boolean                   @default(false)
  referralCode                String?                   @unique
  referralCommissionBal       Float                     @default(0)
  referredById                String?
  subscribedToNewsletter      Boolean                   @default(true)
  regId                       String?                   @unique
  currentSessionToken         String?
  adminMessages               AdminMessage[]
  receivedMessages            AdminMessageRecipient[]
  announcements               Announcement[]
  assignmentSubmissions       AssignmentSubmission[]
  attendances                 Attendance[]
  instructedBatches           Batch[]
  batchNotes                  BatchNote[]
  blogPosts                   BlogPost[]
  candidateProfile            CandidateProfile?
  certificates                Certificate[]             @relation("CertificateUser")
  approvedCertificates        Certificate[]             @relation("CertificateApprover")
  Course                      Course[]
  assignedDemos               DemoSchedule[]            @relation("AssignedDemoTo")
  employerProfile             EmployerProfile?
  enrollments                 Enrollment[]
  enrollmentRequests          EnrollmentRequest[]
  comments                    ForumComment[]
  posts                       ForumPost[]
  internshipsAsMentor         InternshipEnrollment[]    @relation("InternMentor")
  internshipsAsStudent        InternshipEnrollment[]    @relation("InternUser")
  interviews                  Interview[]
  jobs                        Job[]
  applications                JobApplication[]
  conductedJobInterviews      JobInterview[]
  lessonComments              LessonComment[]
  lessonProgress              LessonProgress[]
  libraryBookmarks            LibraryBookmark[]
  sentMessages                Message[]
  notifications               Notification[]
  payments                    Payment[]
  referralRewardsAsReferred   ReferralReward[]          @relation("ReferredRewards")
  referralRewardsAsReferrer   ReferralReward[]          @relation("ReferrerRewards")
  resume                      Resume?
  reviews                     Review[]
  staffAttendances            StaffAttendance[]
  staffGoals                  StaffGoal[]
  payrollRecords              StaffPayroll[]
  assignedTasks               Task[]                    @relation("AssignedTo")
  createdTasks                Task[]                    @relation("CreatedBy")
  taskComments                TaskComment[]
  tickets                     Ticket[]
  sentTicketMessages          TicketMessage[]
  institute                   Institute?                @relation(fields: [instituteId], references: [id])
  referredBy                  User?                     @relation("UserReferrals", fields: [referredById], references: [id])
  referralsMade               User[]                    @relation("UserReferrals")
  systemRole                  SystemRole?               @relation(fields: [systemRoleId], references: [id])
  conversations               Conversation[]            @relation("UserConversations")
  // Campus & Consultancy
  campusDrivesEmployer        CampusDrive[]             @relation("EmployerCampusDrives")
  campusDriveParticipations   CampusDriveStudent[]
  bulkUploads                 BulkUploadLog[]
  consultancyCoordsAsEmployer ConsultancyCoordination[] @relation("EmployerCoordination")
  consultancyCoordsAsAdmin    ConsultancyCoordination[] @relation("AdminCoordination")
  blogComments                BlogComment[]
  customerId                  String?
  customer                    Customer?                 @relation(fields: [customerId], references: [id])
  
  // Gamification
  xp                          Int                       @default(0)
  currentStreak               Int                       @default(0)
  lastLoginDate               DateTime?
  badges                      UserBadge[]

  createdAssessments          Assessment[]
  assessmentAttempts          AssessmentAttempt[]
  assignedLeads               Lead[]                    @relation("AssignedLeads")
  assignedCustomers           Customer[]                @relation("AssignedCustomers")
  consultingResources         ConsultingResource[]
  consultingProjects          ConsultingProject[]
  BlogReaction                BlogReaction[]
  franchiseId                 String?
  franchise                   Franchise?                @relation(fields: [franchiseId], references: [id])
  approvedFranchises          Franchise[]               @relation("FranchiseApprover")
  department                  String?
}

model SystemRole {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  permissions     Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model SystemFeature {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  module      String?
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model RolePermission {
  id         String        @id @default(cuid())
  roleId     String
  featureId  String
  canCreate  Boolean       @default(false)
  canRead    Boolean       @default(false)
  canUpdate  Boolean       @default(false)
  canDelete  Boolean       @default(false)
  isDisabled Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  feature    SystemFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  role       SystemRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, featureId])
}

model SystemPermission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())
}

model Institute {
  id                    String                    @id @default(cuid())
  name                  String
  code                  String?                   @unique
  logoUrl               String?
  address               String?
  website               String?
  phone                 String?
  email                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  batches               Batch[]
  courses               Course[]
  users                 User[]
  type                  InstituteType             @default(TRAINING_INSTITUTE)
  status                InstituteStatus           @default(APPROVED)
  contactPerson         String?
  state                 String?
  district              String?
  city                  String?
  accreditation         String?
  themeColor            String?
  certificateTemplateId String?
  emailTemplate         String?
  landingPageUrl        String?
  subdomain             String?                   @unique
  campusDrives          CampusDriveInstitute[]
  bulkUploads           BulkUploadLog[]
  consultancyCoords     ConsultancyCoordination[]

  departments       String[] @default([])
  branches          String[] @default([])
  academicYears     String[] @default([])
  placementCalendar Json?
}

model Course {
  id                   String              @id @default(cuid())
  title                String
  description          String
  thumbnail            String?
  category             String
  difficulty           Difficulty          @default(BEGINNER)
  price                Decimal             @default(0)
  instructorId         String
  isPublished          Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  duration             Int                 @default(0)
  bundlePrice          Decimal             @default(0)
  hasInterviewPrep     Boolean             @default(false)
  interviewPrice       Decimal             @default(0)
  averageRating        Float               @default(0)
  bannerUrl            String?
  courseCode           String?             @unique
  courseType           CourseType          @default(RECORDED)
  discountPrice        Decimal             @default(0)
  hybridConfig         Json?
  jobRoles             Json?
  liveSchedule         Json?
  publishStatus        PublishStatus       @default(DRAFT)
  publishedAt          DateTime?
  reviewNotes          String?
  submittedForReviewAt DateTime?
  instituteId          String?
  categoryId           String?
  jobPrep              Boolean             @default(false)
  couponId             String?
  admissionFee         Decimal             @default(1000)
  benefits             Json?
  fakeEnrolledCount    Int                 @default(0)
  fakeRating           Float?
  requireAdmissionFee  Boolean             @default(true)
  specialOffers        Json?
  pageViews            Int                 @default(0)
  salaryExperienced    String?
  salaryFresher        String?
  toolsCovered         String[]            @default([])
  faqs                 Json?
  metaDescription      String?
  seoTitle             String?
  slug                 String?             @unique
  targetKeywords       String[]
  careerOpportunities  Json?
  learningOutcomes     Json?
  prerequisites        Json?
  projects             Json?
  salaryInsights       Json?
  announcements        Announcement[]
  batches              Batch[]
  certificates         Certificate[]
  assessments          Assessment[]
  courseCategory       CourseCategory?     @relation(fields: [categoryId], references: [id])
  Coupon               Coupon?             @relation(fields: [couponId], references: [id])
  institute            Institute?          @relation(fields: [instituteId], references: [id])
  franchiseId          String?
  franchise            Franchise?          @relation(fields: [franchiseId], references: [id])
  instructor           User                @relation(fields: [instructorId], references: [id])
  enrollments          Enrollment[]
  enrollmentRequests   EnrollmentRequest[]
  liveClasses          LiveClass[]
  meetings             Meeting[]
  modules              Module[]
  payments             Payment[]
  reviews              Review[]

  @@unique([title, instructorId])
}

model CourseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?  @default("#6366f1")
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
}

model Batch {
  id               String         @id @default(cuid())
  name             String
  courseId         String
  instructorId     String
  startDate        DateTime?
  endDate          DateTime?
  description      String?
  maxStudents      Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  instituteId      String?
  batchCode        String         @unique
  hasJobAssistance Boolean        @default(false)
  isActive         Boolean        @default(true)
  timings          String?
  status           String         @default("UPCOMING")
  announcements    Announcement[]
  attendances      Attendance[]
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institute        Institute?     @relation(fields: [instituteId], references: [id])
  instructor       User           @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  notes            BatchNote[]
  enrollments      Enrollment[]
  interviews       Interview[]
  liveClasses      LiveClass[]
}

model Attendance {
  id        String   @id @default(cuid())
  batchId   String
  userId    String
  date      DateTime
  status    String
  notes     String?
  minutesSpent Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId, date])
}

model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String
  priority     String   @default("NORMAL")
  courseId     String?
  batchId      String?
  instructorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  batch        Batch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course       Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model BatchNote {
  id               String    @id @default(cuid())
  batchId          String
  userId           String
  content          String
  type             String    @default("COMMENT")
  requestedEndDate DateTime?
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  batch            Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonComment {
  id                   String          @id @default(cuid())
  lessonId             String
  userId               String
  content              String
  parentId             String?
  isPinned             Boolean         @default(false)
  isInstructorResponse Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lesson               Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent               LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies              LessonComment[] @relation("CommentReplies")
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderIndex  Int
  isPublished Boolean  @default(false)
  lessons     Lesson[]
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, orderIndex])
}

model Lesson {
  id                    String                 @id @default(cuid())
  moduleId              String
  title                 String
  content               String?
  videoUrl              String?
  duration              Int?
  order                 Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  isPreview             Boolean                @default(false)
  isPublished           Boolean                @default(false)
  resources             Json?
  settings              Json?
  type                  LessonType             @default(VIDEO)
  assignmentSubmissions AssignmentSubmission[]
  module                Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  comments              LessonComment[]
  progress              LessonProgress[]
  quizzes               Quiz[]
}

model Quiz {
  id            String   @id @default(cuid())
  lessonId      String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  createdAt     DateTime @default(now())
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  content   String?
  fileUrl   String?
  grade     Int?
  feedback  String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                 String           @id @default(cuid())
  userId             String
  courseId           String
  progress           Int              @default(0)
  status             EnrollmentStatus @default(ACTIVE)
  enrolledAt         DateTime         @default(now())
  completedAt        DateTime?
  hasInterviewAccess Boolean          @default(false)
  enrollmentMode     String           @default("ONLINE") // ONLINE, OFFLINE
  batchId            String?
  batch              Batch?           @relation(fields: [batchId], references: [id])
  course             Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments       Installment[]

  @@unique([userId, courseId])
}

model EnrollmentRequest {
  id            String                  @id @default(cuid())
  userId        String
  courseId      String
  name          String
  email         String
  phone         String?
  qualification String?
  status        EnrollmentRequestStatus @default(PENDING)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  course        Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  timeSpent      Int      @default(0)
  lastAccessedAt DateTime @default(now())
  score          Int?
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Interview {
  id              String               @id @default(cuid())
  userId          String
  domain          String
  company         String?
  role            String
  jobDescription  String?
  resumeUrl       String?
  difficulty      Difficulty           @default(INTERMEDIATE)
  panelCount      Int                  @default(1)
  status          InterviewStatus      @default(SCHEDULED)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  linkedCourseId  String?
  duration        Int                  @default(30)
  mode            String               @default("FULL")
  technology      String?
  selectedAvatars String[]
  aiAvatarUrl     String?
  batchId         String?
  batch           Batch?               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation      InterviewEvaluation?
  questions       InterviewQuestion[]
  responses       InterviewResponse[]
  jobApplications JobApplication[]
}

model InterviewQuestion {
  id          String             @id @default(cuid())
  interviewId String
  avatarId    String?
  question    String
  type        QuestionType
  order       Int
  avatarRole  String?
  interview   Interview          @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  response    InterviewResponse?
}

model InterviewResponse {
  id          String            @id @default(cuid())
  interviewId String
  questionId  String            @unique
  transcript  String?
  videoUrl    String?
  audioUrl    String?
  duration    Int?
  respondedAt DateTime          @default(now())
  code        String?
  feedback    String?
  score       Int?
  interview   Interview         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question    InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model InterviewEvaluation {
  id                 String    @id @default(cuid())
  interviewId        String    @unique
  overallScore       Int
  technicalScore     Int
  communicationScore Int
  confidenceScore    Int
  starMethodScore    Int
  strengths          Json
  weaknesses         Json
  recommendations    Json
  aiInsights         String?
  createdAt          DateTime  @default(now())
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Avatar {
  id          String   @id @default(cuid())
  name        String
  role        String
  personality String
  avatarUrl   String
  voiceId     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  gender      Gender?  @default(MALE)
  provider    String?  @default("ELEVEN_LABS")
}

model KnowledgeBase {
  id          String          @id @default(cuid())
  domain      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  status      KnowledgeStatus @default(PUBLISHED)
  answer      String?
  content     String
  difficulty  Difficulty      @default(INTERMEDIATE)
  topic       String
  codeSnippet String?
  tags        Json?
  type        QuestionType    @default(TECHNICAL)
}

model InterviewSettings {
  id                  String   @id @default(cuid())
  adaptiveDifficulty  Boolean  @default(true)
  escalationThreshold Int      @default(75)
  initialDifficulty   String   @default("INTERMEDIATE")
  maxQuestions        Int      @default(10)
  hrQuestionRatio     Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id            String     @id @default(cuid())
  orderId       String     @unique
  paymentId     String?    @unique
  signature     String?
  amount        Float
  currency      String     @default("INR")
  status        String     @default("PENDING")
  paymentMethod String     @default("ONLINE") // ONLINE, CASH_FRANCHISE
  userId        String
  courseId      String
  franchiseId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  course        Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id])
  franchise     Franchise? @relation(fields: [franchiseId], references: [id])
}

model Installment {
  id           String      @id @default(cuid())
  enrollmentId String
  amount       Float
  dueDate      DateTime
  status       String      @default("PENDING") // PENDING, PAID, OVERDUE
  paidDate     DateTime?
  paymentId    String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model ForumCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  slug        String      @unique
  icon        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  posts       ForumPost[]
}

model ForumPost {
  id         String         @id @default(cuid())
  title      String
  content    String
  slug       String         @unique
  authorId   String
  categoryId String
  likes      Int            @default(0)
  views      Int            @default(0)
  isPinned   Boolean        @default(false)
  isSolved   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  comments   ForumComment[]
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   ForumCategory  @relation(fields: [categoryId], references: [id])
}

model ForumComment {
  id         String    @id @default(cuid())
  content    String
  postId     String
  authorId   String
  parentId   String?
  isSolution Boolean   @default(false)
  likes      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post       ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String    @id @default(cuid())
  name         String?
  isGroup      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("UserConversations")
}

model AdminMessage {
  id                 String                  @id @default(cuid())
  title              String
  content            String
  senderId           String
  priority           String                  @default("NORMAL")
  isPublished        Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  attachmentUrl      String?
  category           String?
  expiresAt          DateTime?
  isHtml             Boolean                 @default(false)
  parentId           String?
  scheduledFor       DateTime?
  AdminMessage       AdminMessage?           @relation("AdminMessageToAdminMessage", fields: [parentId], references: [id])
  other_AdminMessage AdminMessage[]          @relation("AdminMessageToAdminMessage")
  sender             User                    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  recipients         AdminMessageRecipient[]
}

model AdminMessageRecipient {
  id        String       @id @default(cuid())
  messageId String
  userId    String
  isRead    Boolean      @default(false)
  readAt    DateTime?
  createdAt DateTime     @default(now())
  message   AdminMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readBy         Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum CertificateStatus {
  PENDING
  ISSUED
  REVOKED
  EXPIRED
}

model Certificate {
  id               String               @id @default(cuid())
  uniqueId         String               @unique
  userId           String?
  regId            String?
  courseId         String? // Made optional for Webinars/Events
  enrollmentId     String? // Made optional for Webinars/Events
  referenceId      String? // Links to Webinar, Workshop, Event
  referenceType    String? // "COURSE", "WEBINAR", "WORKSHOP", "EVENT"
  studentName      String
  courseName       String // Can double as Event/Webinar Name
  courseCategory   String?
  trainingHours    Int? // New Enterprise Field
  skillsEarned     Json? // New Enterprise Field
  learningOutcomes Json? // New Enterprise Field
