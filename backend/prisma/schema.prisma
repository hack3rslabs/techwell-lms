generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  password               String
  name                   String
  role                   Role                    @default(STUDENT)
  plan                   Plan                    @default(FREE)
  avatar                 String?
  phone                  String?
  isActive               Boolean                 @default(true)
  emailVerified          Boolean                 @default(false)
  permissions            Json?
  dob                    DateTime?
  qualification          String?
  college                String?
  instituteId            String?
  leadLastSeenAt         DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  systemRoleId           String?
  announcements          Announcement[]
  assignmentSubmissions  AssignmentSubmission[]
  instructedBatches      Batch[]
  blogPosts              BlogPost[]
  certificates           Certificate[]
  employerProfile        EmployerProfile?
  enrollments            Enrollment[]
  enrollmentRequests     EnrollmentRequest[]
  comments               ForumComment[]
  posts                  ForumPost[]
  interviews             Interview[]
  jobs                   Job[]
  applications           JobApplication[]
  conductedJobInterviews JobInterview[]
  lessonComments         LessonComment[]
  lessonProgress         LessonProgress[]
  libraryBookmarks       LibraryBookmark[]
  sentMessages           Message[]
  adminMessages          AdminMessage[]
  receivedMessages       AdminMessageRecipient[]
  payments               Payment[]
  reviews                Review[]
  assignedTasks          Task[]                  @relation("AssignedTo")
  createdTasks           Task[]                  @relation("CreatedBy")
  taskComments           TaskComment[]
  tickets                Ticket[]
  sentTicketMessages     TicketMessage[]
  institute              Institute?              @relation(fields: [instituteId], references: [id])
  systemRole             SystemRole?             @relation(fields: [systemRoleId], references: [id])
  conversations          Conversation[]          @relation("UserConversations")
  notifications          Notification[]
  batchNotes             BatchNote[]
  candidateProfile       CandidateProfile?
  resume                 Resume?
  twoFactorEnabled       Boolean                 @default(false)
  twoFactorSecret        String?
  twoFactorTempSecret    String?
  trustedDevices         Json?                   @default("[]")
  attendances            Attendance[]
  staffAttendances       StaffAttendance[]
  assignedDemos          DemoSchedule[]          @relation("AssignedDemoTo")
  staffGoals             StaffGoal[]
  Course                 Course[]
  internshipsAsStudent   InternshipEnrollment[]  @relation("InternUser")
  internshipsAsMentor    InternshipEnrollment[]  @relation("InternMentor")
  payrollRecords         StaffPayroll[]
  
  // GDPR
  subscribedToNewsletter Boolean                 @default(true)
  deleteRequested        Boolean                 @default(false)
  deleteRequestDate      DateTime?

  // Referrals
  referralCode           String?                 @unique
  referredById           String?
  referralCommissionBal  Float                   @default(0)
  referredBy             User?                   @relation("UserReferrals", fields: [referredById], references: [id])
  referralsMade          User[]                  @relation("UserReferrals")
  referralRewardsAsReferrer ReferralReward[]     @relation("ReferrerRewards")
  referralRewardsAsReferred ReferralReward[]     @relation("ReferredRewards")
}

model SystemRole {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  permissions     Json? // Legacy permissions field
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
}

model SystemFeature {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique // e.g., "COURSES", "USERS"
  module      String? // e.g., "Academics", "Management"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model RolePermission {
  id         String        @id @default(cuid())
  roleId     String
  featureId  String
  canRead    Boolean       @default(false)
  canWrite   Boolean       @default(false)
  isDisabled Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  role       SystemRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  feature    SystemFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([roleId, featureId])
}

model SystemPermission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())
}

model Institute {
  id        String   @id @default(cuid())
  name      String
  code      String?  @unique
  logoUrl   String?
  address   String?
  website   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   Batch[]
  courses   Course[]
  users     User[]
}

model Course {
  id                   String              @id @default(cuid())
  title                String
  description          String
  thumbnail            String?
  category             String
  categoryId           String?
  difficulty           Difficulty          @default(BEGINNER)
  duration             Int                 @default(0)
  price                Decimal             @default(0)
  discountPrice        Decimal             @default(0)
  courseCode           String?             @unique
  jobRoles             Json?
  bannerUrl            String?
  averageRating        Float               @default(0)
  instructorId         String
  isPublished          Boolean             @default(false)
  hasInterviewPrep     Boolean             @default(false)
  jobPrep              Boolean             @default(false)
  interviewPrice       Decimal             @default(0)
  bundlePrice          Decimal             @default(0)
  courseType           CourseType          @default(RECORDED)
  liveSchedule         Json?
  hybridConfig         Json?
  publishStatus        PublishStatus       @default(DRAFT)
  publishedAt          DateTime?
  reviewNotes          String?
  submittedForReviewAt DateTime?
  instituteId          String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  announcements        Announcement[]
  batches              Batch[]
  institute            Institute?          @relation(fields: [instituteId], references: [id])
  courseCategory       CourseCategory?     @relation(fields: [categoryId], references: [id])
  enrollments          Enrollment[]
  enrollmentRequests   EnrollmentRequest[]
  liveClasses          LiveClass[]
  modules              Module[]
  payments             Payment[]
  reviews              Review[]
  certificates         Certificate[]
  meetings             Meeting[]
  Coupon               Coupon?             @relation(fields: [couponId], references: [id])
  couponId             String?

  fakeEnrolledCount   Int     @default(0)
  fakeRating          Float?
  benefits            Json?
  specialOffers       Json?
  requireAdmissionFee Boolean @default(true)
  admissionFee        Decimal @default(1000)

  // New High-Converting Page Fields
  toolsCovered      String[] @default([])
  salaryFresher     String?
  salaryExperienced String?
  pageViews         Int      @default(0)

  // SEO Fields (Phase 1)
  slug            String?  @unique
  seoTitle        String?
  metaDescription String?
  targetKeywords  String[]
  faqs            Json? // [{question: "", answer: ""}]

  // SEO Content Fields (Phase 2)
  careerOpportunities Json? // [{ role: string, description: string }]
  salaryInsights      Json? // [{ role: string, min: string, max: string, average: string }]
  projects            Json? // [{ title: string, description: string, duration: string }]
  prerequisites       Json? // [string]
  learningOutcomes    Json? // [string]

  // Relations
  instructor User @relation(fields: [instructorId], references: [id])

  @@unique([title, instructorId])
}

model CourseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?  @default("#6366f1")
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
}

model Batch {
  id               String         @id @default(cuid())
  batchCode        String         @unique // Auto-generated e.g. B-YYYY-MM-001
  name             String
  courseId         String
  instructorId     String
  instituteId      String?
  startDate        DateTime?
  endDate          DateTime?
  timings          String? // e.g. "10:00 AM - 12:00 PM"
  description      String?
  maxStudents      Int?
  hasJobAssistance Boolean        @default(false)
  isActive         Boolean        @default(true)
  status           String         @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  announcements    Announcement[]
  notes            BatchNote[]
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institute        Institute?     @relation(fields: [instituteId], references: [id])
  instructor       User           @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments      Enrollment[]
  attendances      Attendance[]
  liveClasses      LiveClass[]
  interviews       Interview[]
}

model Attendance {
  id        String   @id @default(cuid())
  batchId   String
  userId    String
  date      DateTime
  status    String // PRESENT, ABSENT, LATE, EXCUSED
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId, date])
}

model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String
  priority     String   @default("NORMAL")
  courseId     String?
  batchId      String?
  instructorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  batch        Batch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course       Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model BatchNote {
  id               String    @id @default(cuid())
  batchId          String
  userId           String
  content          String
  type             String    @default("COMMENT") // COMMENT, EXTENSION_REQUEST
  requestedEndDate DateTime?
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonComment {
  id                   String          @id @default(cuid())
  lessonId             String
  userId               String
  content              String
  parentId             String?
  isPinned             Boolean         @default(false)
  isInstructorResponse Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lesson               Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent               LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies              LessonComment[] @relation("CommentReplies")
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, orderIndex])
}

model Lesson {
  id                    String                 @id @default(cuid())
  moduleId              String
  title                 String
  content               String?
  videoUrl              String?
  duration              Int?
  order                 Int
  type                  LessonType             @default(VIDEO)
  isPublished           Boolean                @default(false)
  isPreview             Boolean                @default(false)
  settings              Json?
  resources             Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assignmentSubmissions AssignmentSubmission[]
  module                Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  comments              LessonComment[]
  progress              LessonProgress[]
  quizzes               Quiz[]
}

model Quiz {
  id            String   @id @default(cuid())
  lessonId      String
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  createdAt     DateTime @default(now())
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  content   String?
  fileUrl   String?
  grade     Int?
  feedback  String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                 String           @id @default(cuid())
  userId             String
  courseId           String
  progress           Int              @default(0)
  status             EnrollmentStatus @default(ACTIVE)
  hasInterviewAccess Boolean          @default(false)
  batchId            String?
  enrolledAt         DateTime         @default(now())
  completedAt        DateTime?
  batch              Batch?           @relation(fields: [batchId], references: [id])
  course             Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model EnrollmentRequest {
  id            String                  @id @default(cuid())
  userId        String
  courseId      String
  name          String
  email         String
  phone         String?
  qualification String?
  status        EnrollmentRequestStatus @default(PENDING)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  course        Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  score          Int?
  timeSpent      Int      @default(0)
  lastAccessedAt DateTime @default(now())
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Interview {
  id              String               @id @default(cuid())
  userId          String
  domain          String
  company         String?
  role            String
  technology      String?
  jobDescription  String?
  resumeUrl       String?
  difficulty      Difficulty           @default(INTERMEDIATE)
  panelCount      Int                  @default(1)
  linkedCourseId  String?
  duration        Int                  @default(30)
  selectedAvatars String[]
  aiAvatarUrl     String?
  status          InterviewStatus      @default(SCHEDULED)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  batchId         String?
  batch           Batch?               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation      InterviewEvaluation?
  questions       InterviewQuestion[]
  responses       InterviewResponse[]
}

model InterviewQuestion {
  id          String             @id @default(cuid())
  interviewId String
  avatarId    String?
  question    String
  type        QuestionType
  order       Int
  avatarRole  String?
  interview   Interview          @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  response    InterviewResponse?
}

model InterviewResponse {
  id          String            @id @default(cuid())
  interviewId String
  questionId  String            @unique
  transcript  String?
  code        String?
  videoUrl    String?
  audioUrl    String?
  duration    Int?
  respondedAt DateTime          @default(now())
  feedback    String?
  score       Int?
  interview   Interview         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question    InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model InterviewEvaluation {
  id                 String    @id @default(cuid())
  interviewId        String    @unique
  overallScore       Int
  technicalScore     Int
  communicationScore Int
  confidenceScore    Int
  starMethodScore    Int
  strengths          Json
  weaknesses         Json
  recommendations    Json
  aiInsights         String?
  createdAt          DateTime  @default(now())
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Avatar {
  id          String   @id @default(cuid())
  name        String
  role        String
  personality String
  avatarUrl   String
  gender      Gender?  @default(MALE)
  voiceId     String?
  provider    String?  @default("ELEVEN_LABS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model KnowledgeBase {
  id          String          @id @default(cuid())
  domain      String
  topic       String
  content     String
  answer      String?
  difficulty  Difficulty      @default(INTERMEDIATE)
  type        QuestionType    @default(TECHNICAL)
  codeSnippet String?
  tags        Json?
  status      KnowledgeStatus @default(PUBLISHED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model InterviewSettings {
  id                  String   @id @default(cuid())
  adaptiveDifficulty  Boolean  @default(true)
  escalationThreshold Int      @default(75)
  initialDifficulty   String   @default("INTERMEDIATE")
  maxQuestions        Int      @default(10)
  hrQuestionRatio     Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  paymentId String?  @unique
  signature String?
  amount    Float
  currency  String   @default("INR")
  status    String   @default("PENDING")
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ForumCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  slug        String      @unique
  icon        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  posts       ForumPost[]
}

model ForumPost {
  id         String         @id @default(cuid())
  title      String
  content    String
  slug       String         @unique
  authorId   String
  categoryId String
  likes      Int            @default(0)
  views      Int            @default(0)
  isPinned   Boolean        @default(false)
  isSolved   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  comments   ForumComment[]
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   ForumCategory  @relation(fields: [categoryId], references: [id])
}

model ForumComment {
  id         String    @id @default(cuid())
  content    String
  postId     String
  authorId   String
  parentId   String?
  isSolution Boolean   @default(false)
  likes      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post       ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String    @id @default(cuid())
  name         String?
  isGroup      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("UserConversations")
}

model AdminMessage {
  id          String                  @id @default(cuid())
  title       String
  content     String
  senderId    String
  priority    String                  @default("NORMAL")
  isPublished Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  sender      User                    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  recipients  AdminMessageRecipient[]
}

model AdminMessageRecipient {
  id        String       @id @default(cuid())
  messageId String
  userId    String
  isRead    Boolean      @default(false)
  readAt    DateTime?
  createdAt DateTime     @default(now())
  message   AdminMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readBy         Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String               @id @default(cuid())
  uniqueId        String               @unique
  userId          String
  courseId        String
  enrollmentId    String
  studentName     String
  courseName      String
  courseCategory  String?
  issueDate       DateTime             @default(now())
  startDate       DateTime?
  endDate         DateTime?
  expiryDate      DateTime?
  templateId      String?
  signatureUrl    String?
  signatoryName   String?
  signatoryTitle  String?
  verificationUrl String?
  isValid         Boolean              @default(true)
  grade           String?
  score           Float?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  template        CertificateTemplate? @relation(fields: [templateId], references: [id])
  course          Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CertificateTemplate {
  id           String        @id @default(cuid())
  name         String
  description  String?
  designUrl    String
  previewUrl   String?
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  layout       Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  certificates Certificate[]
}

model CertificateSettings {
  id                    String   @id @default(cuid())
  instituteId           String   @unique @default("default")
  prefix                String   @default("CERT")
  yearInId              Boolean  @default(true)
  sequenceDigits        Int      @default(5)
  currentSequence       Int      @default(0)
  defaultSignatureUrl   String?
  defaultSignatoryName  String   @default("Director")
  defaultSignatoryTitle String   @default("Academic Director")
  signaturePosition     String   @default("bottom-center")
  logoPosition          String   @default("header")
  logoSize              String   @default("medium")
  signatureSize         String   @default("medium")
  borderStyle           String   @default("classic")
  backgroundUrl         String?
  defaultValidityMonths Int?
  instituteName         String   @default("Techwell Academy")
  instituteLogoUrl      String?
  stampUrl              String?
  stampPosition         String   @default("bottom-right")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AIProvider {
  id           String   @id @default(cuid())
  name         String
  provider     String
  apiKey       String
  model        String
  endpoint     String?
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  usageLimit   Int?
  currentUsage Int      @default(0)
  lastResetAt  DateTime @default(now())
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(2048)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AIUsageLog {
  id         String   @id @default(cuid())
  providerId String
  userId     String?
  feature    String
  tokensUsed Int
  promptHash String?
  createdAt  DateTime @default(now())
}

model VideoIntegration {
  id           String    @id @default(cuid())
  platform     String
  name         String
  clientId     String?
  clientSecret String?
  apiKey       String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean   @default(false)
  webhookUrl   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model LiveClass {
  id                String          @id @default(cuid())
  courseId          String
  title             String
  description       String?
  platform          String
  meetingLink       String?
  meetingId         String?
  password          String?
  scheduledAt       DateTime
  duration          Int
